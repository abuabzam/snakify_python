n = int(input())
if n == 0 :
    print(0)
elif n==1 :
    print(1)
else:
    
    previous = 0
    current = 1
    index = 1
    while True :
        feb = current + previous
        previous = current
        current = feb
        index +=1
        if current == n :
            print(index)
            break

        elif current > n:
            print(-1)
            break
